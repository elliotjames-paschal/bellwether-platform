  "agent_rules": {
    "description": "Agents are NOT enumerated. Use these formatting rules:",
    "people": "Last name, ALL CAPS. Examples: 'Donald Trump' → TRUMP, 'Jerome Powell' → POWELL",
    "people_ambiguous": "If last name is ambiguous, use FIRST_LAST: 'Hillary Clinton' → H_CLINTON, 'Bill Clinton' → B_CLINTON",
    "institutions": "Standard abbreviation, ALL CAPS: 'Federal Reserve' → FED, 'Supreme Court' → SCOTUS, 'Bureau of Labor Statistics' → BLS",
    "parties": "Standard abbreviation: 'Democratic Party' → DEM, 'Republican Party' → GOP, 'Labour Party' → LAB",
    "countries": "ISO 3166-1 alpha-2: 'United States' → US, 'United Kingdom' → UK, 'Germany' → DE",
    "us_states": "Two-letter postal code: 'California' → CA, 'Texas' → TX"
  },

  "target_rules": {
    "description": "Targets are NOT enumerated. Use these formatting rules:",
    "offices": "Standard abbreviation: 'President' → PRES, 'Vice President' → VP, 'House' → HOUSE, 'Senate' → SENATE, 'Governor' → GOV, 'Fed Chair' → FED_CHAIR, 'Cabinet' → CABINET",
    "economic": "Standard abbreviation: 'GDP' → GDP, 'CPI' → CPI, 'unemployment rate' → UNEMPLOYMENT, 'federal funds rate' → FFR",
    "bills": "Short descriptive slug, ALL CAPS: 'tax reform bill' → TAX_REFORM, 'immigration bill' → IMMIGRATION, 'debt ceiling' → DEBT_CEILING",
    "general": "Short descriptive slug, ALL CAPS, underscores for spaces: 'Time Person of the Year' → TIME_POTY"
  },

  "threshold_rules": {
    "description": "Thresholds encode numeric conditions:",
    "comparison": "GT (>), LT (<), GTE (>=), LTE (<=), EQ (=): 'above 2.0%' → GT_2.0PCT, 'at least 25bps' → GTE_25BPS, 'exactly 4.2%' → EQ_4.2PCT",
    "range": "Use underscore for ranges: 'between 1.0% and 1.5%' → 1.0_1.5PCT",
    "counts": "For counts: 'at least 3' → GTE_3, 'exactly 2' → EQ_2",
    "basis_points": "25BPS, 50BPS, 75BPS, 100BPS",
    "none": "If no threshold applies: ANY"
  },

  "timeframe_rules": {
    "description": "Timeframes derived from end_date field:",
    "year": "If end_date is Dec 31: use year only → 2025",
    "year_adjusted": "If end_date is Jan 1-20: use previous year (market is about that year)",
    "quarter": "For quarterly data: 2025_Q3",
    "month": "For monthly data or specific meetings: MAR2026, SEP2025",
    "term": "For full presidential term: 2029 (end of term)"
  }
