# =============================================================================
# Bellwether Platform - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & Credentials (NEVER commit these)
# -----------------------------------------------------------------------------
.env
.env.*
*.env
!.env.example
*_api_key.txt
*_api_key*.txt
credentials.json
secrets.json
*.pem
*.key

# -----------------------------------------------------------------------------
# Data Files (too large for git, use cloud storage)
# -----------------------------------------------------------------------------
data/*.csv
data/*.json
data/*.parquet
data/*.pkl
data/*.pickle
!data/.gitkeep
!data/schemas/
*.csv
*.parquet

# Specific large data patterns
combined_political_markets*.csv
backtest_*.json
prototype_matches.json

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/cache
.pnpm-store/

# -----------------------------------------------------------------------------
# IDE & Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# LaTeX (keep source, ignore build artifacts)
# -----------------------------------------------------------------------------
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.toc
*.synctex.gz
*.pytxcode
pythontex-files-*/
*conflicted copy*

# -----------------------------------------------------------------------------
# Build & Deploy
# -----------------------------------------------------------------------------
.wrangler/
.cloudflare/
dist/
build/
.next/
.vercel/

# -----------------------------------------------------------------------------
# Logs & Temp
# -----------------------------------------------------------------------------
logs/
*.log
tmp/
temp/
.cache/

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Icon?

# -----------------------------------------------------------------------------
# Backups (from Dropbox sync issues)
# -----------------------------------------------------------------------------
*conflicted copy*
BACKUP_*/
*.bak
